# Vercel Ignore - Exclude these from deployment

# Backend files
backend/
*.pyc
__pycache__/
*.py[cod]
*$py.class

# Environment files (add via Vercel dashboard)
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies (will be installed during build)
node_modules/
frontend/node_modules/

# Testing
coverage/
.coverage

# Database
*.db
*.sqlite

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Misc
.git/
.github/
README.md
